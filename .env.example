# =========================================================================
# FIREBASE ANDROID CONFIGURATION GUIDE
#
# 1. Create a file named ".env" in the root directory of the project.
# 2. Copy the keys below (the uncommented lines)
#    and paste them into your new ".env" file.
# 3. Replace the placeholder values with the actual credentials from the
#    Firebase Console (Project Settings > General > Your Apps).
# 4. IMPORTANT: Never commit your ".env" file to GitHub. It contains
#    sensitive keys that should remain local to your machine.
# =========================================================================

# Our Google Cloud / Firebase API Key
ANDROID_API_KEY=our_api_key_here

# Our Firebase Android App ID (from Firebase Console)
ANDROID_APP_ID=1:xxxxxxxxxxxx:android:xxxxxxxxxxxxxxxxxxxxxx

# Our Firebase Project Number / Sender ID
ANDROID_MESSAGING_SENDER_ID=our_messaging_sender_id

# Our Firebase Project ID
ANDROID_PROJECT_ID=our_project_id

# Our Firebase Storage Bucket URL
ANDROID_STORAGE_BUCKET=our_storage_bucket_url